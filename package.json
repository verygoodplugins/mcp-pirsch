{
  "name": "@verygoodplugins/mcp-pirsch",
  "version": "0.1.0",
  "description": "MCP server for Pirsch Analytics: stats, comparisons, trends",
  "main": "dist/index.js",
  "type": "module",
  "mcpName": "io.github.verygoodplugins/mcp-pirsch",
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "mcp-pirsch": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && npm run postbuild",
    "postbuild": "chmod +x dist/index.js",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "modelcontextprotocol",
    "pirsch",
    "analytics",
    "reporting"
  ],
  "author": "Very Good Plugins",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/verygoodplugins/mcp-pirsch.git"
  },
  "bugs": {
    "url": "https://github.com/verygoodplugins/mcp-pirsch/issues"
  },
  "homepage": "https://github.com/verygoodplugins/mcp-pirsch#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^17.3.1",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.2.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.57.2",
    "vitest": "^3.0.0"
  }
}
