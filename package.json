{
  "name": "@verygoodplugins/mcp-pirsch",
  "version": "0.1.2",
  "description": "MCP server for Pirsch Analytics: stats, comparisons, trends",
  "main": "dist/index.js",
  "type": "module",
  "mcpName": "io.github.verygoodplugins/mcp-pirsch",
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "mcp-pirsch": "dist/index.js"
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "prebuild": "npm run clean",
    "build": "tsc -p tsconfig.build.json",
    "postbuild": "chmod +x dist/index.js",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "modelcontextprotocol",
    "pirsch",
    "analytics",
    "reporting"
  ],
  "author": "Very Good Plugins",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/verygoodplugins/mcp-pirsch.git"
  },
  "bugs": {
    "url": "https://github.com/verygoodplugins/mcp-pirsch/issues"
  },
  "homepage": "https://github.com/verygoodplugins/mcp-pirsch#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "server.json"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.1",
    "dotenv": "^17.2.3",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.8"
  }
}
